<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="ComboBox.DefaultComboBox">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceSecondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="MaxDropDownHeight" Value="200"/>
    </Style>
    
    <Style Selector="ComboBox.DefaultComboBox /template/ Path#DropDownGlyph">
        <Setter Property="Fill" Value="Red" />
    </Style>
    
    <Style Selector="Border.InnerSurface">
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceCard}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceSecondary}"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    
    <Style Selector="ToggleSwitch.SettingsToggle">
        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
        <Setter Property="OffContent" Value=""/> <Setter Property="OnContent" Value=""/>
    </Style>
    
    <Style Selector="Path.BaseIcon">
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Stroke" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="StrokeThickness" Value="1.8"/>
        <Setter Property="StrokeJoin" Value="Round"/>
        <Setter Property="StrokeLineCap" Value="Round"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />

    </Style>
</Styles>
