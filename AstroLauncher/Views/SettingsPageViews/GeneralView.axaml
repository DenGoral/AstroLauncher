<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:viewModels="clr-namespace:AstroLauncher.ViewModels.SettingsPageViewModels"
             x:DataType="viewModels:GeneralViewModel"
             x:CompileBindings="True"
             x:Class="AstroLauncher.Views.SettingsPageViews.GeneralView">

    <Border>
        <StackPanel Margin="15" Spacing="3">
            <TextBlock Text="General" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                       HorizontalAlignment="Left"/>
        
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Visible">
                
                
            </ScrollViewer>
        </StackPanel>    
    </Border>

</UserControl>