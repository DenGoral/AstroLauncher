<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:viewModels="clr-namespace:AstroLauncher.ViewModels.SettingsPageViewModels"
             x:DataType="viewModels:GeneralViewModel"
             x:CompileBindings="True"
             x:Class="AstroLauncher.Views.SettingsPageViews.GeneralView">
    
    <UserControl.Styles>
        <Style Selector="Grid.SettingRow">
            <Setter Property="ColumnDefinitions" Value="*, Auto"/>
        </Style>
    </UserControl.Styles>

    <Border>
        <StackPanel Margin="15" Spacing="3">
            <TextBlock Text="General" Classes="Header"/>
        
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Visible">
                
                <Border Classes="InnerSurface">
                    <StackPanel Spacing="11" Margin="5">
                        <!-- START ON STARTUP -->
                        <Grid Classes="SettingRow">
                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Start on system startup" FontSize="15"/>
                                <TextBlock Text="Launch Astro Launcher when your computer starts" Classes="Description"/>
                            </StackPanel>
                            
                            <ToggleSwitch Grid.Column="1" Foreground="{DynamicResource AccentColor}"
                                          OnContent="" OffContent=""/>
                        </Grid>
                        
                        <!-- MINIMIZE TO TRAY -->
                        <Grid Classes="SettingRow">
                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Minimize to system tray" FontSize="15"/>
                                <TextBlock Text="Close button will minimize the launcher to tray" Classes="Description"/>
                            </StackPanel>
                            
                            <ToggleSwitch Grid.Column="1" Foreground="{DynamicResource AccentColor}"
                                          OnContent="" OffContent=""/>
                        </Grid>
                        
                        <!-- LANGUAGE -->
                        <Grid Classes="SettingRow">
                            <Path Grid.Column="0" 
                                  Data="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10"
                                  HorizontalAlignment="Left"/>
                            
                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Language" FontSize="15"/>
                                <TextBlock Text="Choose your preferred language" Classes="Description"/>
                            </StackPanel>
                            
                            <ComboBox Grid.Column="2" Classes="DefaultComboBox" Width="150" VerticalAlignment="Center"
                                      ItemsSource="{Binding Languages}" SelectedItem="{Binding ChosenLanguage}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </StackPanel>    
    </Border>

</UserControl>