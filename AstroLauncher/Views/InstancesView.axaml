<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:viewModels="clr-namespace:AstroLauncher.ViewModels"
             x:DataType="viewModels:InstancesViewModel"
             x:CompileBindings="True"
             x:Class="AstroLauncher.Views.InstancesView">

    <Grid>
        <StackPanel Margin="15" Spacing="8">
            <TextBlock Text="Instances" Classes="Header"/>
            <TextBlock Text="Manage your Minecraft installations" Classes="Description"/>
             
            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                <AutoCompleteBox PlaceholderText="Search instances..." 
                                 PlaceholderForeground="{DynamicResource TextSecondary}"
                                 FilterMode="Contains" MinimumPrefixLength="1"
                                 BorderBrush="{DynamicResource AccentColor}" 
                                 BorderThickness="1"
                                 CornerRadius="5"
                                 VerticalAlignment="Center">
                    
                    <AutoCompleteBox.InnerLeftContent>
                        <Path Data="{StaticResource SearchIcon}" Margin="8,0,0,0" Classes="BaseIcon"
                              Stroke="{DynamicResource TextSecondary}"/>
                    </AutoCompleteBox.InnerLeftContent>
                </AutoCompleteBox>
                          
                <Button Classes="BaseBtn" Margin="8,0,0,0" Grid.Column="1">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Path Data="{StaticResource PlusIcon}" Classes="BaseIcon"/>
                        <TextBlock Text="Create New" VerticalAlignment="Center"/>
                    </StackPanel> 
                </Button>
            </Grid>
            
            <!-- FILTER TOGGLE BUTTONS -->
            <StackPanel Orientation="Horizontal" Spacing="5">
                <ToggleButton Classes="SecondaryBtn" Content="All (5)"/>
                <ToggleButton Classes="SecondaryBtn" Content="Favorites (1)"/>
            </StackPanel>
                          
            <ScrollViewer Margin="0,10,0,0">
                <ListBox Background="Transparent">
                    <ListBoxItem Classes="BaseListBox"/>
                </ListBox>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>