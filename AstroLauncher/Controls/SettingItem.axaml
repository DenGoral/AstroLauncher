<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:AstroLauncher.Controls">
    
    <Design.PreviewWith>
        <controls:SettingItem Header="Test" Description="Desc"/>
    </Design.PreviewWith>

    <Style Selector="controls|SettingItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,5">
                    <Path Data="{TemplateBinding IconData}" 
                          HorizontalAlignment="Left" 
                          VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" Margin="10,5">
                        <TextBlock Text="{TemplateBinding Header}" FontSize="15"/>
                        <TextBlock Text="{TemplateBinding Description}" Classes="Description"/>
                    </StackPanel>

                    <ContentPresenter Grid.Column="2" 
                                      Content="{TemplateBinding Content}"
                                      VerticalAlignment="Center"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
