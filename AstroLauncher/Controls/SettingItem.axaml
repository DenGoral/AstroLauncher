<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:AstroLauncher.Controls">
    
    <Design.PreviewWith>
        <controls:SettingItem Header="Test" Description="Desc"/>
    </Design.PreviewWith>

    <Style Selector="controls|SettingItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Classes="InnerSurface" Margin="5" Padding="16,12">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="40, *, Auto">
                        <Path Grid.Row="0" Grid.Column="0" 
                              Data="{TemplateBinding IconData}" 
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Margin="0,4,0,0"
                              Stroke="White" Stretch="Uniform"
                              Width="24" Height="24"/>
            
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                            <TextBlock Text="{TemplateBinding Header}" FontSize="14" FontWeight="Medium"/>
                            <TextBlock Text="{TemplateBinding Description}" Classes="Description" Opacity="0.6" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
            
                        <ContentPresenter Grid.Column="2" Grid.Row="0" Content="{TemplateBinding ActionContent}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"/>
            
                        <ContentPresenter Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                          Content="{TemplateBinding LowerContent}"
                                          Margin="0,10,0,0"/>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
